# NestJS 백엔드 주소 (브라우저·서버 양쪽에서 사용)
# 로컬 예: http://localhost:3000  (프론트 포트와 다르면 백엔드 CORS origin·FRONTEND_URL을 프론트 주소로 맞출 것)
NEXT_PUBLIC_API_URL=http://localhost:3000

# resumes/likes/bookmarks 목업 토글. 백엔드 미구현 동안 기본 ON.
# 해당 엔드포인트가 준비되면 false 로 바꿔 실제 API를 호출한다.
NEXT_PUBLIC_USE_MOCK=true

# 인증 목업(데모 유저) — 기본 OFF (실제 구글 로그인 사용).
# 백엔드 없이 /me·편집 화면까지 둘러보고 싶을 때만 true 로.
NEXT_PUBLIC_MOCK_AUTH=false